# ─── Google OAuth ─────────────────────────────────────────────────────────────
# OAuth 2.0 Client ID (Tipo: Aplicativo Web)
# Crie em: console.cloud.google.com → APIs → Credenciais
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ID da planilha do Google Sheets
# Extraia da URL: docs.google.com/spreadsheets/d/<ID>/edit
VITE_SPREADSHEET_ID=your-spreadsheet-id

# ─── Alertas por E-mail (EmailJS) ─────────────────────────────────────────────
# Crie uma conta gratuita em: https://emailjs.com (até 200 e-mails/mês)
#
# 1. Conecte um serviço de e-mail (Gmail, Outlook…)  → copie o Service ID
# 2. Crie um template com as variáveis abaixo         → copie o Template ID
# 3. Vá em Account → General → Public Key            → copie a chave
#
# Variáveis disponíveis no template EmailJS:
#   {{to_email}}       → destinatário
#   {{subject}}        → assunto automático
#   {{produtos_lista}} → lista formatada de produtos em alerta
#   {{total_alertas}}  → número total de alertas
#   {{criticos}}       → número de produtos com estoque zero
#   {{data_hora}}      → data/hora do envio (horário local)
VITE_EMAILJS_PUBLIC_KEY=your-emailjs-public-key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx

# E-mail de destino para os alertas
VITE_ALERT_EMAIL=estoque@suaempresa.com.br

# ─── Login Admin (somente área Admin) ─────────────────────────────────────────
VITE_ADMIN_USER=admin
VITE_ADMIN_PASSWORD=sua-senha-segura
